<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../static/styles/main.css" />
  <link rel="stylesheet" href="../static/styles/partials/nav.css" />
  <link rel="stylesheet" href="../static/styles/partials/footer.css" />
  <link rel="stylesheet" href="../static/styles/partials/cookie-banner.css" />
  <link rel="stylesheet" href="../static/styles/privacy.css" />
  <title>Privacy Policy - Taskify</title>
</head>

<body>
  <%- include("../views/partials/nav.ejs") %>

  <main id="main-content" class="privacy-page">
    <section class="privacy-hero" aria-labelledby="privacy-heading">
      <div class="privacy-container">
        <p class="privacy-hero-eyebrow">Legal</p>
        <h1 id="privacy-heading" class="privacy-hero-title">Privacy Policy</h1>
        <p class="privacy-updated">Last updated: 30 April 2026</p>
        <p class="privacy-lead">
          How Taskify collects, uses, and protects personal information for this CPT304 coursework project (Express, EJS, MongoDB).
        </p>
      </div>
    </section>

    <div class="privacy-container privacy-content">
      <h2>Information we process</h2>
      <ul>
        <li>Account data you submit (for example username and email).</li>
        <li>Login/session data needed to keep you signed in securely.</li>
        <li>Basic security logs (for example request time and IP) for abuse prevention.</li>
      </ul>

      <h2>How we use information</h2>
      <p>
        We use the information to provide account features, keep the service secure, and maintain the application.
      </p>

      <h2>Cookies</h2>
      <p>
        Taskify uses essential cookies for session and security. Optional cookie choices are managed by the cookie banner.
      </p>

      <h2>Your choices</h2>
      <p>
        You can stop using the service at any time. Where available, you can remove your account from the dashboard.
      </p>

      <h2>Contact</h2>
      <p>
        For coursework-related questions, contact the project team through your module communication channels.
      </p>

      <p class="privacy-back"><a href="/">← Back to home</a></p>
    </div>
  </main>

  <%- include("../views/partials/footer.ejs") %>
  <%- include("../views/partials/cookie-banner.ejs") %>
  <script src="/static/js/site-header.js" defer></script>
  <script src="/static/js/cookie-banner.js" defer></script>
</body>

</html>
