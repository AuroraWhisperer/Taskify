<div class="cookie-banner" id="cookieBanner" role="dialog" aria-live="polite" aria-label="Cookie consent banner">
  <p class="cookie-banner-text">
    We use essential cookies to keep Taskify secure and working correctly. You can accept or reject optional cookies.
  </p>
  <div class="cookie-banner-actions">
    <button type="button" id="cookieRejectBtn" class="cookie-banner-btn cookie-banner-btn-secondary">Reject</button>
    <button type="button" id="cookieAcceptBtn" class="cookie-banner-btn cookie-banner-btn-primary">Accept</button>
  </div>
</div>
