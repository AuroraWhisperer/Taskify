<% const isLoginView = typeof showLogin !== "undefined" && showLogin; %>
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../static/styles/signup.css" />
  <link rel="stylesheet" href="../static/styles/partials/cookie-banner.css" />
  <title><%= isLoginView ? "Login" : "SignUp" %></title>
</head>

<body>
  <section class="section signup-section">
    <a href="/" class="auth-home-link" aria-label="Back to home">Taskify</a>
    <div class="container signup-container">
      <div class="main <%= error ? "has-auth-error" : "" %>">
        <% if (error) { %>
          <div class="auth-error"><%= error %></div>
        <% } %>
        <input type="checkbox" id="chk" aria-hidden="true" <%= isLoginView ? "checked" : "" %> />

        <div class="signup">
          <form method="post" action="/signup">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label for="chk" aria-hidden="true">Sign up</label>
            <div class="signup-username">
              <input type="text" name="SignUpUsername" placeholder="User name" autocomplete="username" required="true" />
            </div>
            <div class="signup-email">
              <input type="email" name="SignUpEmail" placeholder="Email" autocomplete="email" autocapitalize="none" spellcheck="false" required="true" />
            </div>
            <div class="signup-password">
              <input type="password" name="SignUpPassword" placeholder="Password" autocomplete="new-password" required="true" />
            </div>
            <div>
              <input class="button" name="SignUpSubmit" type="submit" value="Sign up" />
            </div>
          </form>
        </div>
        <div class="login">
          <form method="post" action="/login" autocomplete="off" data-clear-on-load="true">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <label for="chk" aria-hidden="true">Login</label>
            <div class="signup-email">
              <input type="email" name="LoginEmail" placeholder="Enter your email " autocomplete="off" autocapitalize="none" spellcheck="false" value="" readonly required="true" />
            </div>
            <div class="signup-password">
              <input type="password" name="LoginPassword" placeholder="Enter password" autocomplete="new-password" value="" readonly required="true" />
            </div>
            <!-- <button href="/auth">Log In</button> -->
            <div>
              <input class="button" name="LoginSubmit" type="submit" value="Login" />
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
  <%- include("../views/partials/cookie-banner.ejs") %>
  <script src="/static/js/auth-form.js" defer></script>
  <script src="/static/js/cookie-banner.js" defer></script>
</body>

</html>
